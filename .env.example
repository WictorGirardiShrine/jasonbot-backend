PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase project settings (Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres pooler URL (Settings → Database → Connection pooling, mode=transaction, port 6543)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Comma-separated allowlist of admin emails
ADMIN_EMAILS=jason@jasonandrews.coach,wictor@shrinedev.com

# Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Voyage AI key for KB embeddings (https://dash.voyageai.com)
VOYAGE_API_KEY=

# Stripe (https://dashboard.stripe.com/apikeys) — use test-mode keys (sk_test_…) in dev
STRIPE_SECRET_KEY=
# Generated when you register the webhook endpoint in Stripe dashboard (whsec_…)
STRIPE_WEBHOOK_SECRET=
# Recurring price IDs created in Stripe dashboard for the JasonBot Coaching product
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_ANNUAL_ID=
# Free tier cap — messages per UTC day before the upgrade modal blocks new messages
FREE_TIER_DAILY_MESSAGE_LIMIT=10
