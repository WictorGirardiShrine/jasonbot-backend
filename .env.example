PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase project settings (Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres pooler URL (Settings → Database → Connection pooling, mode=transaction, port 6543)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Comma-separated allowlist of admin emails
ADMIN_EMAILS=jason@jasonandrews.coach,wictor@shrinedev.com

# Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Voyage AI key for KB embeddings (https://dash.voyageai.com)
VOYAGE_API_KEY=
