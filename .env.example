PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase project settings (Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres pooler URL (Settings → Database → Connection pooling, mode=transaction, port 6543)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Comma-separated allowlist of admin emails
ADMIN_EMAILS=jason@jasonandrews.coach,wictor@shrinedev.com

# Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Voyage AI key for KB embeddings (https://dash.voyageai.com)
VOYAGE_API_KEY=

# Stripe — dormant. Only required when BILLING_STRIPE_ENABLED=true.
# (https://dashboard.stripe.com/apikeys) — use test-mode keys (sk_test_…) in dev
STRIPE_SECRET_KEY=
# Generated when you register the webhook endpoint in Stripe dashboard (whsec_…)
STRIPE_WEBHOOK_SECRET=
# Recurring price IDs created in Stripe dashboard for the JasonBot Coaching product
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_ANNUAL_ID=
# Free tier cap — messages per UTC day once beta access has expired
FREE_TIER_DAILY_MESSAGE_LIMIT=10

# Kit (formerly ConvertKit) — Jason's newsletter
# Get a v4 API key at https://app.kit.com/account_settings/developer_settings
# CONVERTKIT_TAG_ID is the numeric ID of the tag we subscribe new JasonBot signups to
# (Subscribers → Tags → click the tag → ID is in the URL).
CONVERTKIT_API_SECRET=
CONVERTKIT_TAG_ID=

# Feature flag — keep Stripe code dormant during the free-beta phase
BILLING_STRIPE_ENABLED=false

# Beta length in days granted to each newly signed-up user
BETA_ACCESS_DURATION_DAYS=30
